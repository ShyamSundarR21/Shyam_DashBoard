# ─── Server ───────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── AWS Credentials ──────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=YOUR_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_SECRET_ACCESS_KEY

# ─── DynamoDB ─────────────────────────────────────────
DYNAMODB_WASTE_TABLE=dinewave-waste-entries
DYNAMODB_SENSOR_TABLE=dinewave-sensor-readings
DYNAMODB_LEDGER_TABLE=dinewave-immutable-ledger
DYNAMODB_ALERTS_TABLE=dinewave-alerts

# ─── AWS IoT Core ─────────────────────────────────────
IOT_ENDPOINT=xxxxxxxxxxxxxx-ats.iot.us-east-1.amazonaws.com
IOT_TOPIC_SENSORS=dinewave/sensors/#
IOT_TOPIC_WASTE=dinewave/waste
IOT_TOPIC_SANITIZE=dinewave/sanitize
IOT_CLIENT_ID=dinewave-server

# ─── JWT Auth ─────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=24h

# ─── WebSocket ────────────────────────────────────────
WS_PORT=8080

# ─── Sanitization Thresholds ──────────────────────────
UV_TRIGGER_WASTE_COUNT=10
MIST_TRIGGER_HUMIDITY=80
BIN_CAPACITY_ALERT_PERCENT=85
